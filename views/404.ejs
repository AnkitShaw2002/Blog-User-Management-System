<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>404 - Page Not Found | BlogMS</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
  <style>
    body { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); min-height: 100vh; }
  </style>
</head>
<body class="hold-transition">
  <div class="d-flex align-items-center justify-content-center" style="min-height:100vh;">
    <div class="text-center text-white">
      <h1 style="font-size:8rem;font-weight:bold;opacity:0.3;">404</h1>
      <h3 class="mb-3"><i class="fas fa-exclamation-triangle mr-2"></i>Page Not Found</h3>
      <p class="text-muted mb-4">The page you are looking for does not exist.</p>
      <a href="/blogs" class="btn btn-primary mr-2"><i class="fas fa-newspaper mr-1"></i>Browse Blogs</a>
      <a href="/login" class="btn btn-outline-light"><i class="fas fa-sign-in-alt mr-1"></i>Login</a>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
