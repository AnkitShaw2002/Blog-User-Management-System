<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= typeof title !== 'undefined' ? title + ' | BlogMS' : 'BlogMS' %></title>

<link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
<style>
  .flash-messages { position: fixed; top: 60px; right: 20px; z-index: 9999; min-width: 280px; }
  .blog-img-thumb { width: 80px; height: 60px; object-fit: cover; border-radius: 4px; }
  .profile-img-sm { width: 36px; height: 36px; object-fit: cover; border-radius: 50%; }
  .blog-card-img { width: 100%; height: 200px; object-fit: cover; border-radius: 6px 6px 0 0; }
  .card-blog { transition: transform .2s; }
  .card-blog:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,.12); }
  .badge-role-admin { background: #dc3545; color:#fff; padding:3px 8px; border-radius:10px; font-size:11px; }
  .badge-role-user  { background: #007bff; color:#fff; padding:3px 8px; border-radius:10px; font-size:11px; }
</style>
